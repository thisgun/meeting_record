# HuggingFace 토큰 (선택사항 · 무료 · pyannote 화자분리 전용)
# - 비워두면: 로컬 화자 분리(speechbrain ECAPA-TDNN) 자동 사용. 정확도 중간, 인증 불필요.
# - 채우면:  pyannote 사용. 정확도 더 높음. https://hf.co/settings/tokens 에서 read 토큰 발급 후
#            speaker-diarization-3.1 + segmentation-3.0 두 모델 약관 동의 필요.
# - 🪟 Windows 주의: pyannote 4.x + speechbrain 1.x 조합은 k2 의존성 문제로 대체로 실패합니다.
#            토큰을 넣어도 자동으로 speechbrain fallback → Windows면 비워두는 걸 권장. (자세히는 README)
HUGGINGFACE_TOKEN=

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
# 기본 요약 모델: gemma4:e2b-it-qat (Q4 양자화, ~4.3GB) — 8GB VRAM에 100% GPU로 적재됨.
# 풀프리시전 gemma4:e2b(7.7GB)는 8GB GPU에서 CPU 분할/요약 실패 위험 → QAT 권장.
# VRAM 여유가 크면 gemma4:e4b-it-qat(6.1GB) 등 더 큰 모델도 가능.
OLLAMA_MODEL=gemma4:e2b-it-qat
# Ollama 메모리/컨텍스트 안전 기본값
# - keep_alive=0: 요약 후 모델을 붙잡지 않고 즉시 해제
# - 100분 안팎 긴 회의는 32768 권장. 짧은 회의만 8192~16384 가능
OLLAMA_KEEP_ALIVE=0
OLLAMA_NUM_CTX_MAX=32768
OLLAMA_NUM_PREDICT=8192
# 빈 값=Ollama 자동. 0=GPU offload 끄고 CPU만 사용(충분한 RAM 필요).
# 999처럼 전체 GPU 강제 값은 저VRAM에서 위험하므로 사용하지 마세요.
OLLAMA_NUM_GPU=
# 첫 토큰/다음 청크 대기 제한. 콜드 로딩 60~90초는 정상, 이 값을 넘으면 실패 처리.
OLLAMA_TIMEOUT_SEC=300
# 긴 회의는 이 초 단위로 나눠 구간별 상세 요약 후 최종 통합. 0이면 분할 비활성화.
OLLAMA_SUMMARY_CHUNK_SEC=900
# 이 값보다 free RAM이 낮으면 Ollama 호출을 시작하지 않고 캐시만 남긴 뒤 종료
OLLAMA_MIN_FREE_RAM_GB=4
OLLAMA_MEMORY_WAIT_SEC=30

# 하드웨어 가속
# auto: GPU 감지 시 cuda, 아니면 cpu (권장)
# cpu / cuda: 강제 지정. python doctor.py 로 가용성 확인.
DEVICE=auto

# Whisper STT
WHISPER_MODEL=small               # tiny/base/small/medium/large-v3
WHISPER_COMPUTE_TYPE=              # 빈 값=자동 (cpu→int8, cuda→float16)
WHISPER_LANGUAGE=ko
WHISPER_CPU_THREADS=0              # 0=자동
WHISPER_BATCH_SIZE=8               # RTX 3050 4GB/저메모리는 4~8 권장, VRAM 8GB+면 16
WHISPER_VAD_FILTER=1
WHISPER_CONDITION_ON_PREVIOUS_TEXT=1   # 1=기본(또렷한 회의 권장). 음악/잡음 많아 환각·반복 심하면 0

# STT 후 오타/오인식 후처리 보정
# 1이면 도메인 사전(dict.py) 치환 규칙과 아래 간단 규칙을 적용합니다.
TYPO_CORRECTION=1
# 간단 치환 규칙. 여러 개는 ; 로 구분합니다. 정규식이 아니라 문자 그대로 바꿉니다.
# 예: TYPO_CORRECTION_RULES=중대재수자=>중대재해;태양관=>태양광;지개차=>지게차
TYPO_CORRECTION_RULES=
# 로컬 Ollama에게 명백한 STT 오타만 추가 검사하게 합니다. 느릴 수 있어 기본 off.
TYPO_CORRECTION_AI=0
# 빈 값이면 OLLAMA_MODEL 사용.
TYPO_CORRECTION_AI_MODEL=
# 한 번에 AI 보정할 발화 수. 낮추면 느리지만 안정적입니다.
TYPO_CORRECTION_AI_CHUNK_SIZE=30

# 자동 품질 점검
# STT/화자 분리 결과가 위험하면 회의록 상단에 경고를 붙입니다.
QUALITY_CHECK=1
# 1이면 품질이 "낮음"으로 판정된 회의록은 G5 자동 업로드를 차단하고 로컬 DB에만 저장합니다.
# 꼭 업로드해야 하면 main.py --force-upload 또는 QUALITY_BLOCK_UPLOAD=0을 사용하세요.
QUALITY_BLOCK_UPLOAD=1

# 게시글/요약 본문 하단에 처리 정보(오디오 길이·처리 시간·화자 수·모델) 한 줄 표시. 끄려면 0.
POST_PROCESSING_FOOTER=1

# 개인정보(PII) 마스킹
# 회의 중 노출된 주민번호·휴대폰·전화·이메일·카드·계좌번호를 자동으로 가립니다.
# 관공서/민감 회의를 다루는 도구이므로 기본값을 partial로 권장합니다.
#   off     : 마스킹 안 함
#   partial : 일부만 가림 (예: 901234-1****567) — 권장
#   full    : 카테고리 라벨로 대체 (예: [주민번호])
# 주의: 회의 중 언급된 긴 숫자(예산·통계 등)가 드물게 오탐 마스킹될 수 있습니다.
#       정확한 숫자가 더 중요하면 off로 두되, 게시판 공개 전 직접 검수하세요.
PII_MASK_LEVEL=partial

# 그누보드5 API
# 표준 위치: 그누보드5 원본의 plugin/meeting_api/ 폴더 (원본 무수정 - 새 폴더만 추가)
# 로컬: http://127.0.0.1/gnuboard5/plugin/meeting_api
# 원격: https://YOUR-DOMAIN/gnuboard5_FOLDER_NAME/plugin/meeting_api
G5_API_BASE=http://127.0.0.1/gnuboard5/plugin/meeting_api
G5_API_TOKEN=
G5_BO_TABLE=meeting

# 멀티 타겟 (로컬 + 원격 동시 등록): G5_TARGETS 활성화
# G5_TARGETS=local,remote
# G5_API_BASE_LOCAL=http://127.0.0.1/gnuboard5/plugin/meeting_api
# G5_API_TOKEN_LOCAL=...
# G5_API_BASE_REMOTE=https://YOUR-DOMAIN/gnu5615/plugin/meeting_api
# G5_API_TOKEN_REMOTE=...
# 기존 단일 G5 설정(default)을 멀티 타겟 중 어느 이름으로 승계할지 지정
# G5_LEGACY_TARGET=remote

# 백업 스크립트 (scripts/backup.py)
# MYSQLDUMP_PATH=C:\xampp\mysql\bin\mysqldump.exe
MYSQL_DATABASE=meeting
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=

# 경로
DB_PATH=./data/meetings.db
WORK_DIR=./data/work
UPLOAD_DIR=./data/uploads

# Streamlit 웹 UI 보안
# 기본값은 잠금 상태입니다. UI를 쓰려면 강력한 비밀번호를 설정하세요.
STREAMLIT_ACCESS_PASSWORD=
# 로컬 테스트에서만 인증을 끄고 싶을 때 1로 설정 (운영/외부 접속 금지)
STREAMLIT_ALLOW_NO_AUTH=0
# 로그인 세션 유지 시간(초). 0이면 만료 없음. 기본 12시간.
STREAMLIT_SESSION_TTL_SEC=43200
# 비밀번호 실패 제한. 기본 5회 실패 시 300초 잠금.
STREAMLIT_AUTH_MAX_ATTEMPTS=5
STREAMLIT_AUTH_LOCKOUT_SEC=300
# 실패 횟수/잠금 상태 파일. 비워두면 ./data/app_auth_state.json
STREAMLIT_AUTH_STATE_PATH=

# 폴더 자동 감시 (watcher.py)
WATCH_DIR=./data/watch
# 지원 확장자: mp3, m4a, wav, amr, aac, ogg, flac, wma, mp4
# 다인원 회의에서 자동 추정이 1~2명으로 뭉치면 실제 예상 화자 수를 지정하세요.
# 예: WATCH_SPEAKERS=6
# 지정하면 기존 STT 캐시가 있어도 화자만 다시 분리해서 캐시를 갱신합니다.
WATCH_SPEAKERS=
WATCH_STABILITY_SEC=5
WATCH_NO_UPLOAD=0
WATCH_LOG=./data/watch.log

# 회의록 RAG 챗봇 (ask.py / qa_watcher.py)
EMBED_MODEL=bge-m3                 # Ollama 임베딩 모델 (ollama pull bge-m3)
RAG_TOP_K=6                        # 검색할 청크 수
QA_BO_TABLE=ask                    # 질문 게시판 (setup_board.php?bo_table=ask 로 생성)
QA_POLL_SEC=20                     # 질문 게시판 폴링 주기(초)
QA_BOT_NAME=회의록봇               # 답변 댓글 작성자명
