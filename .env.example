# HuggingFace 토큰 (선택사항)
# - 비워두면: 로컬 화자 분리(speechbrain ECAPA-TDNN) 자동 사용. 정확도 중간, 인증 불필요.
# - 채우면:  pyannote 사용. 정확도 더 높음. https://hf.co/settings/tokens 에서 read 토큰 발급 후
#            https://hf.co/pyannote/speaker-diarization-3.1 약관 동의 필요.
HUGGINGFACE_TOKEN=

# Ollama
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b
# Ollama 메모리/컨텍스트 안전 기본값
# - keep_alive=0: 요약 후 모델을 붙잡지 않고 즉시 해제
# - RTX 3050 4GB/저메모리 환경은 num_ctx를 8192~16384로 낮추면 안정적
OLLAMA_KEEP_ALIVE=0
OLLAMA_NUM_CTX_MAX=32768
OLLAMA_NUM_PREDICT=8192
# 빈 값=Ollama 자동. 0=GPU offload 끄고 CPU만 사용(충분한 RAM 필요).
# 999처럼 전체 GPU 강제 값은 저VRAM에서 위험하므로 사용하지 마세요.
OLLAMA_NUM_GPU=
# 첫 토큰/다음 청크 대기 제한. 콜드 로딩 60~90초는 정상, 이 값을 넘으면 실패 처리.
OLLAMA_TIMEOUT_SEC=300
# 이 값보다 free RAM이 낮으면 Ollama 호출을 시작하지 않고 캐시만 남긴 뒤 종료
OLLAMA_MIN_FREE_RAM_GB=4
OLLAMA_MEMORY_WAIT_SEC=30

# 하드웨어 가속
# auto: GPU 감지 시 cuda, 아니면 cpu (권장)
# cpu / cuda: 강제 지정. python doctor.py 로 가용성 확인.
DEVICE=auto

# Whisper STT
WHISPER_MODEL=small               # tiny/base/small/medium/large-v3
WHISPER_COMPUTE_TYPE=              # 빈 값=자동 (cpu→int8, cuda→float16)
WHISPER_LANGUAGE=ko
WHISPER_CPU_THREADS=0              # 0=자동
WHISPER_BATCH_SIZE=8               # RTX 3050 4GB/저메모리는 4~8 권장, VRAM 8GB+면 16
WHISPER_VAD_FILTER=1

# 그누보드5 API
# 표준 위치: 그누보드5 원본의 plugin/meeting_api/ 폴더 (원본 무수정 - 새 폴더만 추가)
# 로컬: http://127.0.0.1/gnuboard5/plugin/meeting_api
# 원격: https://YOUR-DOMAIN/gnuboard5_FOLDER_NAME/plugin/meeting_api
G5_API_BASE=http://127.0.0.1/gnuboard5/plugin/meeting_api
G5_API_TOKEN=
G5_BO_TABLE=meeting

# 멀티 타겟 (로컬 + 원격 동시 등록): G5_TARGETS 활성화
# G5_TARGETS=local,remote
# G5_API_BASE_LOCAL=http://127.0.0.1/gnuboard5/plugin/meeting_api
# G5_API_TOKEN_LOCAL=...
# G5_API_BASE_REMOTE=https://YOUR-DOMAIN/gnu5615/plugin/meeting_api
# G5_API_TOKEN_REMOTE=...
# 기존 단일 G5 설정(default)을 멀티 타겟 중 어느 이름으로 승계할지 지정
# G5_LEGACY_TARGET=remote

# 백업 스크립트 (scripts/backup.py)
# MYSQLDUMP_PATH=C:\xampp\mysql\bin\mysqldump.exe
MYSQL_DATABASE=meeting
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=

# 경로
DB_PATH=./data/meetings.db
WORK_DIR=./data/work
UPLOAD_DIR=./data/uploads

# Streamlit 웹 UI 보안
# 기본값은 잠금 상태입니다. UI를 쓰려면 강력한 비밀번호를 설정하세요.
STREAMLIT_ACCESS_PASSWORD=
# 로컬 테스트에서만 인증을 끄고 싶을 때 1로 설정 (운영/외부 접속 금지)
STREAMLIT_ALLOW_NO_AUTH=0
# 로그인 세션 유지 시간(초). 0이면 만료 없음. 기본 12시간.
STREAMLIT_SESSION_TTL_SEC=43200
# 비밀번호 실패 제한. 기본 5회 실패 시 300초 잠금.
STREAMLIT_AUTH_MAX_ATTEMPTS=5
STREAMLIT_AUTH_LOCKOUT_SEC=300
# 실패 횟수/잠금 상태 파일. 비워두면 ./data/app_auth_state.json
STREAMLIT_AUTH_STATE_PATH=

# 폴더 자동 감시 (watcher.py)
WATCH_DIR=./data/watch
WATCH_SPEAKERS=
WATCH_STABILITY_SEC=5
WATCH_NO_UPLOAD=0
WATCH_LOG=./data/watch.log
