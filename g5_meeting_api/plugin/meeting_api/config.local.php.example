<?php
/**
 * 운영 환경 토큰/설정 오버라이드.
 *
 * 이 파일을 config.local.php 로 복사한 뒤 값을 채워 사용.
 * config.php가 이 파일을 먼저 로드하므로 여기서 정의한 값이 적용된다.
 *
 * - config.local.php 는 절대 git에 올리지 말 것 (.gitignore에 등록).
 * - 강력한 랜덤 토큰 생성 (PHP CLI):
 *     php -r "echo bin2hex(random_bytes(24)) . PHP_EOL;"
 */

// 강력한 API 토큰으로 교체 (Python .env의 G5_API_TOKEN과 같은 값으로 맞춤)
// 빈 값 그대로 두면 API가 500으로 실패하여 미설정 상태를 알려준다.
define('meeting_API_TOKEN', '');

// 운영 환경에서는 false 권장 (에러 메시지가 외부에 노출되지 않도록)
define('meeting_API_DEBUG', false);

// 게시판 코드 변경 (기본 'meeting')
// define('meeting_BO_TABLE', 'meeting');

// 게시글 응답 URL이 호스팅 환경에서 잘못 조립되면 공개 그누보드5 루트를 직접 지정하세요.
// 예: https://example.com/gnu5624
// define('meeting_PUBLIC_BASE_URL', 'https://YOUR-DOMAIN/gnu5624');

// setup_board.php를 실행할 때만 true로 바꾸고, 실행 후 false로 되돌리거나 파일을 삭제하세요.
// define('meeting_API_ALLOW_SETUP', true);

